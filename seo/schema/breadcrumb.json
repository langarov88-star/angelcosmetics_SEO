  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Начало",
      "item": "https://www.angelcosmetics.bg/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{TIER1_CATEGORY_NAME}",
      "item": "https://www.angelcosmetics.bg/{TIER1_SLUG}/"
    },
    {
      "_comment": "Add or remove ListItem blocks based on page depth",
      "@type": "ListItem",
      "position": 3,
      "name": "{TIER2_OR_BRAND_OR_SUBCATEGORY_NAME}",
      "item": "https://www.angelcosmetics.bg/{TIER1_SLUG}/{TIER2_SLUG}/"
    },
    {
      "_comment": "Only for product pages or deep pages. Remove for 2-level pages.",
      "@type": "ListItem",
      "position": 4,
      "name": "{PRODUCT_OR_PAGE_NAME}",
      "item": "https://www.angelcosmetics.bg/{FULL_URL_PATH}/"
    }
  ],

