{
  "_comment": "BreadcrumbList Schema Template for angelcosmetics.bg",
  "_instructions": "Replace {PLACEHOLDERS} with real values. Adjust ListItem array per page depth.",
  "_validation": "Test at: https://search.google.com/test/rich-results",
  "_docs": "https://schema.org/BreadcrumbList",
  "_usage": "Add to ALL indexed pages: category, brand, series, product, problem, ingredient, blog",

  "@context": "https://schema.org",
