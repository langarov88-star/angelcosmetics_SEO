{
  "_comment": "Article Schema Template for angelcosmetics.bg Blog",
  "_instructions": "Use on all blog articles. Replace {PLACEHOLDERS} with real values.",
  "_validation": "Test at: https://search.google.com/test/rich-results",
  "_docs": "https://schema.org/Article",
  "_usage": "Blog articles ONLY — not for commercial pages",

  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{ARTICLE_TITLE_MAX_110_CHARS}",
  "description": "{META_DESCRIPTION_OR_ARTICLE_EXCERPT}",
  "image": {
    "@type": "ImageObject",
    "url": "{FEATURED_IMAGE_URL}",
    "width": "{IMAGE_WIDTH}",
    "height": "{IMAGE_HEIGHT}"
  },
  "author": {
    "@type": "Person",
    "name": "{AUTHOR_NAME}",
    "url": "{AUTHOR_PAGE_URL_IF_EXISTS}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Angel Cosmetics",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.angelcosmetics.bg/{LOGO_PATH}"
    }
  },
  "datePublished": "{YYYY-MM-DD}",
  "dateModified": "{YYYY-MM-DD}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://www.angelcosmetics.bg/blog/{ARTICLE_SLUG}/"
  },
  "keywords": "{keyword1, keyword2, keyword3}",
  "articleSection": "{CATEGORY_E.G._Skincare / Hair Care / Ingredients}",
  "inLanguage": "bg",
  "url": "https://www.angelcosmetics.bg/blog/{ARTICLE_SLUG}/"
}
